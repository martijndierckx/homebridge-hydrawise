{
  "name": "homebridge-hydrawise",
  "version": "1.2.1",
  "description": "A homebridge plugin that creates sprinkler accessories for all your Hydrawise zones",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint src/**.ts",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "author": "Martijn Dierckx",
  "engines": {
    "node": ">=16.0.0",
    "homebridge": ">=1.5.0"
  },
  "keywords": [
    "homebridge-plugin",
    "hydrawise"
  ],
  "license": "ISC",
  "files": [
    "dist",
    "troubleshooting",
    "config.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "git://github.com/martijndierckx/homebridge-hydrawise.git"
  },
  "devDependencies": {
    "@homebridge/hap-nodejs": "^2.1.7",
    "@types/node": "^20.19.42",
    "@typescript-eslint/eslint-plugin": "^5.59.5",
    "@typescript-eslint/parser": "^5.59.5",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^8.40.0",
    "eslint-config-prettier": "~8.8.0",
    "homebridge": ">=1.5.0",
    "nodemon": "^2.0.22",
    "prettier": "~2.8.8",
    "rimraf": "^5.0.0",
    "typescript": "^5.0.4",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "hydrawise-api": ">=1.2.1"
  },
  "preferGlobal": true
}
