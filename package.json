{
  "name": "homebridge-hydrawise",
  "version": "2.0.3",
  "description": "A homebridge plugin that creates sprinkler accessories for all your Hydrawise zones",
  "main": "dist/index.js",
  "scripts": {
    "lint": "eslint .",
    "watch": "npm run build && npm link && nodemon",
    "build": "rimraf ./dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "author": "Martijn Dierckx",
  "engines": {
    "node": "^18.20.0 || ^20.18.0 || ^22.12.0 || ^24.0.0",
    "homebridge": "^1.6.0 || ^2.0.0"
  },
  "keywords": [
    "homebridge-plugin",
    "hydrawise"
  ],
  "license": "ISC",
  "files": [
    "dist",
    "troubleshooting",
    "config.schema.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/martijndierckx/homebridge-hydrawise.git"
  },
  "homepage": "https://github.com/martijndierckx/homebridge-hydrawise#readme",
  "bugs": {
    "url": "https://github.com/martijndierckx/homebridge-hydrawise/issues"
  },
  "funding": [
    {
      "type": "paypal",
      "url": "https://paypal.me/martijndierckx"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@homebridge/hap-nodejs": "^2.1.7",
    "@types/node": "^20.19.42",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "homebridge": "^2.1.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "hydrawise-api": "^2.0.1"
  }
}
